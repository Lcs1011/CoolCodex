  {
    "name": "ctool_command_request",
    "description": "Preview and optionally execute a controlled command request using GREEN / YELLOW / RED / BLOCKED policy.",
    "schema_version": "2026-06-ctool-v1",
    "input_schema": {
      "additionalProperties": false,
      "properties": {
        "ai_risk_upgrade": {
          "description": "Optional AI-side risk upgrade. Cannot lower system risk.",
          "enum": [
            "green",
            "yellow",
            "red",
            "blocked"
          ],
          "type": "string"
        },
        "commands": {
          "description": "Ordered command list. Each command is evaluated by command.toml and hard-risk rules.",
          "items": {
            "description": "Command line to preview and possibly execute.",
            "type": "string"
          },
          "type": "array"
        },
        "reason": {
          "description": "Optional request reason shown in audit output.",
          "type": "string"
        },
        "red_first_confirmation": {
          "description": "Required first confirmation only when final risk is RED.",
          "type": "string"
        },
        "red_second_confirmation": {
          "description": "Required second confirmation only when final risk is RED.",
          "type": "string"
        },
        "yellow_confirmation": {
          "description": "Required only when final risk is YELLOW and user approves or rejects.",
          "type": "string"
        }
      },
      "required": [
        "commands"
      ],
      "type": "object"
    },
    "output_schema": {
      "additionalProperties": false,
      "properties": {
        "ai_risk_upgrade": {
          "description": "Optional AI-side risk upgrade.",
          "enum": [
            "GREEN",
            "YELLOW",
            "RED",
            "BLOCKED"
          ],
          "type": "string"
        },
        "all_success": {
          "description": "Whether all executed commands exited successfully. Null when not executed.",
          "type": "boolean"
        },
        "approval_required": {
          "description": "Approval mode: auto, once, twice, or blocked.",
          "type": "string"
        },
        "banner": {
          "description": "Human-readable risk banner.",
          "type": "string"
        },
        "blocked": {
          "description": "Whether the request was blocked.",
          "type": "boolean"
        },
        "command_count": {
          "description": "Number of requested commands.",
          "minimum": 0,
          "type": "integer"
        },
        "commands": {
          "description": "Per-command risk preview list.",
          "items": {
            "additionalProperties": true,
            "description": "Command preview item with command, risk, and reason.",
            "type": "object"
          },
          "type": "array"
        },
        "current_dir": {
          "description": "Command execution current directory.",
          "type": "string"
        },
        "display_text": {
          "description": "Human-readable preview text.",
          "type": "string"
        },
        "executed": {
          "description": "Whether commands executed.",
          "type": "boolean"
        },
        "final_risk": {
          "description": "Final risk after all rules.",
          "enum": [
            "GREEN",
            "YELLOW",
            "RED",
            "BLOCKED"
          ],
          "type": "string"
        },
        "log_file": {
          "description": "Optional audit log file path.",
          "type": "string"
        },
        "note": {
          "description": "Human-readable execution/block/rejection note.",
          "type": "string"
        },
        "rejected": {
          "description": "Whether the user rejected confirmation.",
          "type": "boolean"
        },
        "request_reason": {
          "description": "Optional user/AI reason for the request.",
          "type": "string"
        },
        "result_file": {
          "description": "Optional Markdown result file path.",
          "type": "string"
        },
        "system_risk": {
          "description": "Risk before AI-side upgrade.",
          "enum": [
            "GREEN",
            "YELLOW",
            "RED",
            "BLOCKED"
          ],
          "type": "string"
        },
        "user_feedback": {
          "description": "Optional rejection feedback from user confirmation input.",
          "type": "string"
        },
        "will_execute": {
          "description": "Whether the request will execute in this call.",
          "type": "boolean"
        }
      },
      "required": [],
      "type": "object"
    }
  },
